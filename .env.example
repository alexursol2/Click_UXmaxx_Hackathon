# ---------------------------------------------------------------------------
# Nimbus — environment variables
#
# Copy this file to `.env.local` and fill in your keys.
# All keys below are PUBLISHABLE client-side keys (safe in the browser
# bundle), hence the NEXT_PUBLIC_ prefix. Never put secret/server keys here.
# ---------------------------------------------------------------------------

# --- Magic (embedded email wallet) --- https://dashboard.magic.link
NEXT_PUBLIC_MAGIC_KEY=

# --- Particle Universal Accounts --- https://dashboard.particle.network
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# --- Merchant ---
# Address that receives subscription payments (on the settlement chain).
# For safe testing, use a second address you control.
NEXT_PUBLIC_MERCHANT_ADDRESS=

# --- Pricing (optional) ---
# USD price per cycle when settling in USDC. Default: 5
NEXT_PUBLIC_SUBSCRIPTION_PRICE_USD=

# Settle in native ETH instead of USDC: set to "eth" (default: usdc)
NEXT_PUBLIC_SUBSCRIPTION_TOKEN=
# ETH price per cycle when settling in ETH. Default: 0.001
NEXT_PUBLIC_SUBSCRIPTION_PRICE_ETH=

# Settlement chain id (default: 42161 Arbitrum One; e.g. 8453 for Base)
NEXT_PUBLIC_SUBSCRIPTION_CHAIN_ID=

# --- Demo billing (optional) ---
# Compressed "billing cycle" so judges can watch recurring happen live:
# after the first charge, auto-charge every N seconds, up to MAX total
# charges per session. Leave blank to disable auto-charging.
NEXT_PUBLIC_BILLING_INTERVAL_SECONDS=
NEXT_PUBLIC_BILLING_MAX_CYCLES=
