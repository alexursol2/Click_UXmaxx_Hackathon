# ---------------------------------------------------------------------------
# Click — environment variables
#
# Copy this file to `.env.local` and fill in your keys. `.env.local` is
# gitignored (never committed). All keys below are PUBLISHABLE client-side keys
# (safe in the browser bundle), hence the NEXT_PUBLIC_ prefix.
# NEVER put secret/server keys in here or in .env.local.
# ---------------------------------------------------------------------------

# ===========================================================================
# REQUIRED — the storefront demo needs exactly these five.
# ===========================================================================

# --- Magic (embedded email wallet) --- https://dashboard.magic.link
# Use YOUR publishable key. Add your app origins (e.g. http://localhost:3000
# and your Vercel URL) to the Magic dashboard's Allowed Origins, or logins are
# rejected.
NEXT_PUBLIC_MAGIC_KEY=

# --- Particle Universal Accounts --- https://dashboard.particle.network
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# --- Merchant: address that receives payments (on the settlement chain) ---
# Has a dead-address fallback, so SET THIS or funds go nowhere. For testing,
# use a second address you control.
NEXT_PUBLIC_MERCHANT_ADDRESS=

# ===========================================================================
# OPTIONAL — settlement token/chain. Defaults to USDC on Arbitrum One.
# Only set these if you want the merchant to settle in something else.
# ===========================================================================

# Settlement token: usdc (default) | eth | sol
NEXT_PUBLIC_SUBSCRIPTION_TOKEN=
# Settlement chain id (default: 42161 Arbitrum One; e.g. 8453 for Base).
NEXT_PUBLIC_SUBSCRIPTION_CHAIN_ID=
# Solana receiving address — only needed when settling in SOL.
NEXT_PUBLIC_MERCHANT_ADDRESS_SOL=

# ===========================================================================
# OPTIONAL — cross-chain tuning (sensible defaults; leave blank unless tuning).
# ===========================================================================

# Fixed FLOOR added when Converting funds onto the settlement chain (covers the
# follow-up transfer's gas). The charge also quotes the Convert and tops this up
# if what would actually arrive is short.
NEXT_PUBLIC_CONVERT_BUFFER_USD=       # default 0.4
NEXT_PUBLIC_CONVERT_BUFFER_ETH=       # default 0.0002 (only when settling in ETH)
# Minimum settlement-chain headroom (USD) to insist arrives above the amount.
NEXT_PUBLIC_CONVERT_GAS_FLOOR_USD=    # default 0.05
# Estimated settlement-chain transfer gas added to the cross-chain fee preview.
NEXT_PUBLIC_SETTLE_GAS_USD=           # default 0.03

# ===========================================================================
# SUBSCRIPTION-ONLY — NOT used by the storefront demo (useSubscription hook).
# The demo pays one-off, so you can ignore all of these for the live app.
# ===========================================================================

# Price per cycle (used only by the subscription flow).
NEXT_PUBLIC_SUBSCRIPTION_PRICE_USD=   # default 5
NEXT_PUBLIC_SUBSCRIPTION_PRICE_ETH=   # default 0.001
NEXT_PUBLIC_SUBSCRIPTION_PRICE_SOL=   # default 0.01
# Demo billing: after the first charge, auto-charge every N seconds up to MAX.
NEXT_PUBLIC_BILLING_INTERVAL_SECONDS= # default 0 (off)
NEXT_PUBLIC_BILLING_MAX_CYCLES=       # default 12
# Auto-billing pauses when the balance drops below amount + this. 0 disables it.
NEXT_PUBLIC_LOW_BALANCE_STOP_USD=     # default 0.5
