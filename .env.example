# ---------------------------------------------------------------------------
# Click — environment variables
#
# Copy this file to `.env.local` and fill in your keys. `.env.local` is
# gitignored (never committed). All keys below are PUBLISHABLE client-side keys
# (safe in the browser bundle), hence the NEXT_PUBLIC_ prefix.
# NEVER put secret/server keys in here or in .env.local.
# ---------------------------------------------------------------------------

# --- Magic (embedded email wallet) --- https://dashboard.magic.link
# Use YOUR publishable key. Add your app origins (e.g. http://localhost:3000)
# to the Magic dashboard's Allowed Origins, or logins are rejected.
NEXT_PUBLIC_MAGIC_KEY=

# --- Particle Universal Accounts --- https://dashboard.particle.network
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# --- Merchant ---
# Address that receives payments (on the settlement chain). For safe testing,
# use a second address you control.
NEXT_PUBLIC_MERCHANT_ADDRESS=
# Solana receiving address — only needed when settling in SOL.
NEXT_PUBLIC_MERCHANT_ADDRESS_SOL=

# --- Settlement token: usdc (default) | eth | sol ---
NEXT_PUBLIC_SUBSCRIPTION_TOKEN=
# Settlement chain id (default: 42161 Arbitrum One; e.g. 8453 for Base).
NEXT_PUBLIC_SUBSCRIPTION_CHAIN_ID=

# --- Pricing (optional; used by the subscription demo) ---
# USD price per cycle when settling in USDC. Default: 5
NEXT_PUBLIC_SUBSCRIPTION_PRICE_USD=
# ETH price per cycle when settling in ETH. Default: 0.001
NEXT_PUBLIC_SUBSCRIPTION_PRICE_ETH=
# SOL price per cycle when settling in SOL. Default: 0.01
NEXT_PUBLIC_SUBSCRIPTION_PRICE_SOL=

# --- Demo billing (optional; subscription demo only) ---
# After the first charge, auto-charge every N seconds up to MAX per session.
# Leave INTERVAL blank/0 to disable auto-charging.
NEXT_PUBLIC_BILLING_INTERVAL_SECONDS=
NEXT_PUBLIC_BILLING_MAX_CYCLES=

# --- Cross-chain buffer + safety (optional; sensible defaults) ---
# Fixed FLOOR added to the price when Converting funds onto the settlement
# chain (covers the follow-up transfer's gas). The charge also quotes the
# Convert and tops this up if what would actually arrive is short.
NEXT_PUBLIC_CONVERT_BUFFER_ETH=      # default 0.0002
NEXT_PUBLIC_CONVERT_BUFFER_USD=      # default 0.4
# Minimum settlement-chain headroom (USD) to insist arrives above the price.
NEXT_PUBLIC_CONVERT_GAS_FLOOR_USD=   # default 0.05
# Estimated settlement-chain transfer gas added to the cross-chain fee preview.
NEXT_PUBLIC_SETTLE_GAS_USD=          # default 0.03
# Auto-billing pauses when the unified balance drops below price + this, so a
# live demo can't drain the wallet. Set 0 to disable the guard.
NEXT_PUBLIC_LOW_BALANCE_STOP_USD=    # default 0.5
